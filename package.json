{
  "name": "dailyspark",
  "private": true,
  "version": "0.1.0",
  "description": "DailySpark - Learn something new in 5 minutes a day",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api & npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=packages/types && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "prisma:generate": "npm run prisma:generate --workspace=packages/db",
    "prisma:migrate": "npm run prisma:migrate --workspace=packages/db",
    "prisma:studio": "npm run prisma:studio --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0",
    "@playwright/test": "^1.48.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
